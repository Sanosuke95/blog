development:
  adapter: mysql2
  encoding: utf8mb4
  database: blog
  pool: 5
  username: 
  password:
  socket: /var/run/mysqld/mysqld.sock


production:
  adapter: mysql2
  encoding: utf8mb4
  database: blog_production
  pool: 5
  username: blog
  password: <%= ENV["BLOG_DATABASE_PASSWORD"] %>
  socket: /var/run/mysqld/mysqld.sock
